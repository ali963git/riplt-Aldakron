# ==============================================================================
# Aldakron Backend - Environment Variables
# Copy this file to .env and fill in real values. Never commit .env to git.
# ==============================================================================

NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL="postgresql://aldakron:CHANGE_ME@localhost:5432/aldakron?schema=public"

# JWT secrets - MUST be at least 32 random characters each, and DIFFERENT
# from one another. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="CHANGE_ME_generate_with_openssl_rand_hex_32"
JWT_REFRESH_SECRET="CHANGE_ME_generate_a_different_one"

# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGINS="http://localhost:3000,https://aldakron.app"

# Set to "false" to disable the /api/docs Swagger UI in production
SWAGGER_ENABLED=true

# Optional: if both are set, "npx prisma db seed" creates a first ADMIN
# account with these credentials. Leave unset to skip and promote a user
# to ADMIN manually instead (see INSTALLATION.md).
ADMIN_SEED_EMAIL=admin@aldakron.app
ADMIN_SEED_PASSWORD="CHANGE_ME_Str0ngPassword!"
